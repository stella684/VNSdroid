<SaveLoadPopup>:
    size_hint: 0.7, 0.85
    background_color: 0, 0, 0, 0.85
    
    BoxLayout:
        orientation: 'vertical'
        padding: '20dp'
        spacing: '15dp'
        
        canvas.before:
            Color:
                rgba: 0.05, 0.05, 0.05, 1 
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [12]

        Label:
            text: "SAVE PROGRESS" if root.mode == 'save' else "LOAD PROGRESS"
            font_size: '22sp'
            bold: True
            size_hint_y: None
            height: '40dp'
            color: 1, 1, 1, 1

        ScrollView:
            do_scroll_x: False
            do_scroll_y: True
            
            GridLayout:
                id: slot_container
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: '10dp'

        Button:
            text: "Cancel"
            size_hint_y: None
            height: '50dp'
            background_normal: ''
            background_color: 0.15, 0.15, 0.15, 1 
            color: 1, 1, 1, 1
            on_release: root.dismiss()
