<DrawerButton@Button>:
    font_name: './assets/jpfont.ttf'
    background_normal: ''
    background_color: 0, 0, 0, 0
    size_hint_y: None
    height: '45dp'
    canvas.before:
        Color:
            rgba: (0, 0, 0, 0) if self.state == 'normal' else (0.15, 0.15, 0.18, 0.8)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

<VNInterpreter>:
    canvas.after:
        Color:
            rgba: 0, 0, 0, root.transition_opacity
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # --- CAPTURE LAYER (Background + Sprites Only) ---
        FloatLayout:
            id: capture_layer
            size_hint: 1, 1

            # --- 1. BACKGROUND LAYER ---
            Image:
                id: bg_image
                source: root.bg_source
                allow_stretch: True
                keep_ratio: root.bg_keep_ratio

            # --- 2. CENTERED GAME LAYER ---
            AnchorLayout:
                anchor_x: 'center'
                anchor_y: 'center'

                RelativeLayout:
                    id: game_viewport
                    size_hint: None, None
                    size: bg_image.norm_image_size

                    FloatLayout:
                        id: sprite_layer
                        size_hint: 1, 1
                        
        FloatLayout:
            id: default_ui_layer
            opacity: root.ui_opacity
            disabled: root.ui_hidden
            size_hint: 1, 1

            BoxLayout:
                orientation: 'vertical'
                size_hint: 1, None
                height: '130dp'
                pos_hint: {'x': 0, 'y': 0}
                padding: ['15dp', '5dp', '15dp', '10dp']
                
                canvas.before:
                    Color:
                        rgba: 0, 0, 0, 0.85
                    Rectangle:
                        pos: self.x, self.y
                        size: self.width, self.height - dp(30)
                    Color:
                        rgba: 0, 0, 0, 0.7
                    Rectangle:
                        pos: self.x, self.y + self.height - dp(30)
                        size: self.width, dp(3)
                    Color:
                        rgba: 0, 0, 0, 0.55
                    Rectangle:
                        pos: self.x, self.y + self.height - dp(27)
                        size: self.width, dp(3)
                    Color:
                        rgba: 0, 0, 0, 0.4
                    Rectangle:
                        pos: self.x, self.y + self.height - dp(24)
                        size: self.width, dp(3)
                    Color:
                        rgba: 0, 0, 0, 0.28
                    Rectangle:
                        pos: self.x, self.y + self.height - dp(21)
                        size: self.width, dp(3)
                    Color:
                        rgba: 0, 0, 0, 0.18
                    Rectangle:
                        pos: self.x, self.y + self.height - dp(18)
                        size: self.width, dp(3)
                    Color:
                        rgba: 0, 0, 0, 0.1
                    Rectangle:
                        pos: self.x, self.y + self.height - dp(15)
                        size: self.width, dp(3)
                    Color:
                        rgba: 0, 0, 0, 0.05
                    Rectangle:
                        pos: self.x, self.y + self.height - dp(12)
                        size: self.width, dp(3)
                    Color:
                        rgba: 0, 0, 0, 0.02
                    Rectangle:
                        pos: self.x, self.y + self.height - dp(9)
                        size: self.width, dp(3)
                    Color:
                        rgba: 0, 0, 0, 0.01
                    Rectangle:
                        pos: self.x, self.y + self.height - dp(6)
                        size: self.width, dp(3)

                Label:
                    text: root.char_name
                    font_name: './assets/jpfont.ttf'
                    font_size: '19sp'
                    bold: True
                    outline_width: 2
                    outline_color: 0, 0, 0, 1
                    
                    
                    size_hint: None, None
                    height: '25dp'
                    width: self.texture_size[0]
                    
                    halign: 'left'
                    valign: 'middle'
                    color: 1, 0.85, 0.3, 1

                ScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    
                    Label:
                        text: root.dialogue_text
                        font_name: './assets/jpfont.ttf'
                        font_size: '16sp'
                        size_hint_y: None
                        height: self.texture_size[1]
                        halign: 'left'
                        valign: 'top'
                        text_size: self.width, None
                        color: 1, 1, 1, 1

        FloatLayout:
            id: custom_ui_layer
            size_hint: 1, 1

        Button:
            background_normal: ''
            background_disabled_normal: ''
            background_color: 0, 0, 0, 0
            size_hint: 1, 1
            disabled: root.is_choosing or root.ui_hidden
            on_release: 
                root.close_drawer()
                root.next_line()

        BoxLayout:
            id: choice_layer
            orientation: 'vertical'
            size_hint: 0.8, None
            height: self.minimum_height
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            opacity: 1 if root.is_choosing else 0
            disabled: not root.is_choosing
            spacing: '10dp'
            
            Button:
                text: root.choices[0] if len(root.choices) > 0 else ""
                font_name: './assets/jpfont.ttf'
                size_hint_y: None
                height: '48dp'
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                on_release: root.select_choice(1)
                canvas.before:
                    Color:
                        rgba: (0.09, 0.09, 0.1, 0.95) if self.state == 'normal' else (0.18, 0.18, 0.2, 0.95)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(15)]
            
            Button:
                text: root.choices[1] if len(root.choices) > 1 else ""
                font_name: './assets/jpfont.ttf'
                size_hint_y: None
                height: '48dp'
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                on_release: root.select_choice(2)
                canvas.before:
                    Color:
                        rgba: (0.09, 0.09, 0.1, 0.95) if self.state == 'normal' else (0.18, 0.18, 0.2, 0.95)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(15)]

        FloatLayout:
            opacity: root.ui_opacity
            disabled: root.ui_hidden
            size_hint: 1, 1

            BoxLayout:
                id: side_drawer
                orientation: 'vertical'
                size_hint: 0.35, 1 
                pos_hint: {'x': 1.0, 'y': 0.0} 
                canvas.before:
                    Color:
                        rgba: 0.05, 0.05, 0.05, 0.98
                    Rectangle:
                        pos: self.pos
                        size: self.size

                ScrollView:
                    do_scroll_x: False
                    do_scroll_y: True
                    
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height
                        padding: '15dp'
                        spacing: '12dp'

                        Label:
                            text: "MENU"
                            font_name: './assets/jpfont.ttf'
                            font_size: '22sp'
                            bold: True
                            size_hint_y: None
                            height: '50dp'
                            color: 1, 1, 1, 1

                        DrawerButton:
                            text: "Save Game"
                            on_release: 
                                root.close_drawer()
                                root.open_save_ui()
                        
                        DrawerButton:
                            text: "Load Game"
                            on_release: 
                                root.close_drawer()
                                root.open_load_ui()
                        
                        DrawerButton:
                            text: "Message Log"
                            on_release: 
                                root.close_drawer()
                                root.open_history()
                        
                        DrawerButton:
                            text: "Auto-Play < ON >" if root.auto_mode else "Auto-Play < OFF >"
                          
                            on_release: 
                                root.toggle_auto()
                        
                        DrawerButton:
                            text: "In-Game Settings"
                            on_release: 
                                root.close_drawer()
                                root.open_in_game_settings()
                        
                        DrawerButton:
                            text: "Hide UI"
                            on_release: 
                                root.close_drawer()
                                root.hide_ui()
                        
                        Widget:
                            size_hint_y: None
                            height: '30dp'

                        DrawerButton:
                            text: "Quit to Menu"
                            color: 1, 0.4, 0.4, 1 
                            on_release: 
                                root.close_drawer()
                                root.exit_to_menu()

            Button:
                text: ">" if root.drawer_open else "<"
                font_name: './assets/jpfont.ttf'
                font_size: '24sp'
                size_hint: None, None
                size: '45dp', '45dp'
                x: side_drawer.x - self.width
                top: side_drawer.top - dp(10)
                background_normal: ''
                background_color: 0, 0, 0, 0
                on_release: root.toggle_drawer()
                canvas.before:
                    Color:
                        rgba: (0.05, 0.05, 0.05, 0.95) if self.state == 'normal' else (0.1, 0.1, 0.1, 0.95)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10), 0, 0, dp(10)]

        Button:
            background_normal: ''
            background_color: 0, 0, 0, 0
            opacity: 0
            size_hint: (1, 1) if root.ui_hidden else (None, None)
            size: (0, 0) if not root.ui_hidden else self.size
            on_release: root.unhide_ui()
