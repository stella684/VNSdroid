<VNInterpreter>:

    canvas.after:
        Color:
            rgba: 0, 0, 0, root.transition_opacity
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Image:
            id: bg_image
            source: root.bg_source
            allow_stretch: True
            keep_ratio: root.bg_keep_ratio

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            RelativeLayout:
                size_hint: None, None
                size: bg_image.norm_image_size

                Button:
                    background_color: 0, 0, 0, 0
                    size_hint: 1, 1
                    on_release: root.next_line()

                FloatLayout:
                    id: sprite_layer
                    size_hint: 1, 1

                # --- BUILT-IN DEFAULT UI ---
                FloatLayout:
                    id: default_ui_layer
                    opacity: root.ui_opacity
                    disabled: root.ui_hidden

                    BoxLayout:
                        size_hint: 1, None
                        height: '40dp'
                        pos_hint: {'top': 1.0}
                        orientation: 'horizontal'
                        spacing: '4dp'
                        padding: ['5dp', '2dp', '5dp', '2dp']
                        
                        canvas.before:
                            Color:
                                rgba: 0, 0, 0, 0.4
                            Rectangle:
                                pos: self.pos
                                size: self.size
                            
                        # Spacers to center the buttons
                        Widget:
                            size_hint_x: 1
                            
                        Button:
                            text: "Save"
                            size_hint_x: None
                            width: '55dp'
                            background_normal: ''
                            background_color: 0, 0, 0, 0
                            color: 1, 1, 1, 1
                            on_release: root.open_save_ui()
                            
                        Button:
                            text: "Load"
                            size_hint_x: None
                            width: '55dp'
                            background_normal: ''
                            background_color: 0, 0, 0, 0
                            color: 1, 1, 1, 1
                            on_release: root.open_load_ui()
                            
                        Button:
                            text: "Auto" if not root.auto_mode else "[b]Auto[/b]"
                            markup: True
                            size_hint_x: None
                            width: '55dp'
                            background_normal: ''
                            background_color: 0, 0, 0, 0
                            color: (0.2, 0.8, 0.2, 1) if root.auto_mode else (1, 1, 1, 1)
                            on_release: root.toggle_auto()

                        Button:
                            text: "Log"
                            size_hint_x: None
                            width: '55dp'
                            background_normal: ''
                            background_color: 0, 0, 0, 0
                            color: 1, 1, 1, 1
                            on_release: root.open_history()

                        Button:
                            text: "Hide"
                            size_hint_x: None
                            width: '55dp'
                            background_normal: ''
                            background_color: 0, 0, 0, 0
                            color: 1, 1, 1, 1
                            on_release: root.hide_ui()

                        Button:
                            text: "Set"
                            size_hint_x: None
                            width: '55dp'
                            background_normal: ''
                            background_color: 0, 0, 0, 0
                            color: 1, 1, 1, 1
                            on_release: root.open_in_game_settings()
                            
                        Button:
                            text: "Exit"
                            size_hint_x: None
                            width: '60dp'
                            background_normal: ''
                            background_color: 0, 0, 0, 0
                            color: 0.9, 0.4, 0.4, 1
                            on_release: root.exit_to_menu()
                             
                        # Spacers to center the buttons
                        Widget:
                            size_hint_x: 1

                    BoxLayout:
                        orientation: 'vertical'
                        size_hint: 0.94, None
                        height: '115dp'
                        pos_hint: {'center_x': 0.5, 'y': 0.04}
                        spacing: '2dp'
                        opacity: 1 if root.dialogue_text else 0

                        BoxLayout:
                            size_hint: None, None
                            size: '140dp', '28dp'
                            opacity: 1 if root.char_name.strip() else 0
                            
                            canvas.before:
                                Color:
                                    rgba: 0.08, 0.08, 0.09, 1
                                Rectangle:
                                    pos: self.pos
                                    size: self.size
                                    
                            Label:
                                text: root.char_name
                                font_size: '15sp'
                                font_name: './assets/jpfont.ttf'
                                bold: True
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size
                                color: 1, 0.85, 0.4, 1

                        BoxLayout:
                            padding: ['15dp', '10dp', '15dp', '10dp']
                            canvas.before:
                                Color:
                                    rgba: 0.08, 0.08, 0.09, 0.92
                                Rectangle:
                                    pos: self.pos
                                    size: self.size
                                    
                            Label:
                                text: root.dialogue_text
                                font_size: '17sp'
                                font_name: './assets/jpfont.ttf'
                                halign: 'left'
                                valign: 'top'
                                text_size: self.size
                                color: 0.95, 0.95, 0.95, 1

                    BoxLayout:
                        orientation: 'vertical'
                        size_hint: 0.65, None
                        height: self.minimum_height
                        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                        spacing: '12dp'
                        opacity: 1 if root.is_choosing else 0
                        disabled: not root.is_choosing
                        
                        Button:
                            text: root.choices[0] if len(root.choices) > 0 else ""
                            font_name: './assets/jpfont.ttf'
                            size_hint_y: None
                            height: '48dp'
                            background_normal: ''
                            background_color: 0.09, 0.09, 0.1, 0.95
                            color: 1, 1, 1, 1
                            on_release: root.select_choice(1)
                            
                        Button:
                            text: root.choices[1] if len(root.choices) > 1 else ""
                            font_name: './assets/jpfont.ttf'
                            size_hint_y: None
                            height: '48dp'
                            background_normal: ''
                            background_color: 0.09, 0.09, 0.1, 0.95
                            color: 1, 1, 1, 1
                            on_release: root.select_choice(2)

                FloatLayout:
                    id: custom_ui_layer
                    size_hint: 1, 1


        Button:
            background_color: 0, 0, 0, 0
            opacity: 0
            size_hint: (1, 1) if root.ui_hidden else (None, None)
            size: (0, 0) if not root.ui_hidden else self.size
            on_release: root.unhide_ui()
