<MainMenu>:
    orientation: 'vertical'
    canvas.before:
        Color:
            rgba: 0, 0, 0, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: None
        height: '60dp'
        padding: '10dp'
        spacing: '10dp'
        canvas.before:
            Color:
                rgba: 0.08, 0.08, 0.08, 1
            Rectangle:
                pos: self.pos
                size: self.size
        
        Image:
            source: './assets/icon.png'
            size_hint_x: None
            width: '40dp'
            allow_stretch: True
            keep_ratio: True
        
        Label:
            text: "VNSdroid"
            font_size: '24sp'
            bold: True
            size_hint_x: None
            width: self.texture_size[0]
            text_size: None, self.height
            halign: 'left'
            valign: 'bottom'
            padding_y: '8dp'
            color: 1, 1, 1, 1
        
        Label:
            text: root.app_version
            font_size: '14sp'
            color: 0.5, 0.5, 0.5, 1
            size_hint_x: None
            width: self.texture_size[0]
            text_size: None, self.height
            halign: 'left'
            valign: 'bottom'
            padding_y: '8dp'

        Widget:
            size_hint_x: 1

    ScrollView:
        do_scroll_x: False
        do_scroll_y: True
        BoxLayout:
            id: games_list
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: '15dp'
            spacing: '12dp'

    BoxLayout:
        size_hint_y: None
        height: '55dp'
        spacing: '2dp'
        canvas.before:
            Color:
                rgba: 0.05, 0.05, 0.05, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Button:
            text: "Home"
            font_size: '16sp'
            background_normal: ''
            background_color: 0.08, 0.08, 0.09, 1
            color: 1, 1, 1, 1

        Button:
            text: "Settings"
            font_size: '16sp'
            background_normal: ''
            background_color: 0.08, 0.08, 0.09, 1
            color: 1, 1, 1, 1
            on_release: app.root.current = 'settings_screen'


<GameItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: '90dp'
    padding: '12dp'
    spacing: '15dp'
    
    canvas.before:
        Color:
            rgba: (0.1, 0.1, 0.1, 1) if self.state == 'normal' else (0.18, 0.18, 0.18, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [8]

    Image:
        source: root.icon_path
        size_hint: None, None
        size: '66dp', '66dp'
        allow_stretch: True
        keep_ratio: True
        pos_hint: {'center_y': 0.5}

    Label:
        text: root.game_name
        font_size: '18sp'
        font_name: './assets/jpfont.ttf'
        bold: True
        halign: 'left'
        valign: 'middle'
        text_size: self.size
        color: 1, 1, 1, 1
